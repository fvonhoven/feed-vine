# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# hCaptcha Configuration (for signup form)
# Get your site key from https://dashboard.hcaptcha.com/
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# Stripe Configuration (Frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Monthly Price IDs (Starter/Creator/Builder)
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_starter_monthly_price_id
VITE_STRIPE_PLUS_MONTHLY_PRICE_ID=price_your_creator_monthly_price_id
VITE_STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_your_builder_monthly_price_id

# Annual Price IDs (Starter/Creator/Builder)
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_your_starter_annual_price_id
VITE_STRIPE_PLUS_ANNUAL_PRICE_ID=price_your_creator_annual_price_id
VITE_STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_your_builder_annual_price_id

# Team Plan Monthly Price IDs
VITE_STRIPE_TEAM_MONTHLY_PRICE_ID=price_your_team_starter_monthly_price_id
VITE_STRIPE_TEAM_PRO_MONTHLY_PRICE_ID=price_your_team_pro_monthly_price_id
VITE_STRIPE_TEAM_BUSINESS_MONTHLY_PRICE_ID=price_your_team_business_monthly_price_id

# Team Plan Annual Price IDs
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=price_your_team_starter_annual_price_id
VITE_STRIPE_TEAM_PRO_ANNUAL_PRICE_ID=price_your_team_pro_annual_price_id
VITE_STRIPE_TEAM_BUSINESS_ANNUAL_PRICE_ID=price_your_team_business_annual_price_id

# Stripe Configuration (Backend - for Edge Functions)
# These should be set in Supabase Dashboard > Edge Functions > Secrets
# STRIPE_SECRET_KEY=sk_test_your_secret_key
